    "blur": {
      "radius": 7
    },
    "replace": {
      "pre_blur_radius": 0.8,
      "inset_px": 2,
      "background": {
        "sample_band_px": 3,
        "sample_margin_px": 1
      }
    }
  },
  "rule_modes": {
    "waw_badge": {
      "render_mode": "blur",
      "fallback_render_mode": "fill",
      "bbox_inset_px": 2,
      "blur": {
        "radius": 8
      },
      "modes": [
        {
          "match": {
            "reason_contains": "fallback"
          },
          "bbox_inset_px": 4,
          "blur": {
            "radius": 12
          }
        }
      ]
    },
    "footer_hostname": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "kind": "hostname_primary",
        "fixed": "example.domain.com"
      }
    },
    "hostname_any": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "kind": "hostname_primary",
        "fixed": "example.domain.com"
      }
    },
    "ipv4_any": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "kind": "ipv4_seq",
        "start": "123.123.123.123",
        "step": 1
      }
    },
    "logs_identifiers": {
      "render_mode": "blur",
      "fallback_render_mode": "fill",
      "blur": {
        "radius": 7
      }
    },
    "incoming_events_ids_ips": {
      "render_mode": "blur",
      "fallback_render_mode": "fill",
      "blur": {
        "radius": 7
      },
      "modes": [
        {
          "match": {
            "reason_in": [
              "incoming_ip"
            ]
          },
          "render_mode": "replace",
          "replace": {
            "kind": "ipv4_seq",
            "start": "123.123.123.123",
            "step": 1
          }
        }
      ]
    },
    "general_db_values": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "background": {
          "color": "#FFFFFF"
        },
        "text": {
          "font_family": "Arial",
          "font_size_px": 16,
          "min_font_size_px": 12
        }
      },
      "modes": [
        {
          "match": {
            "reason_in": [
              "sql_host_value"
            ]
          },
          "replace": {
            "kind": "hostname_db",
            "fixed": "db.example.internal"
          }
        },
        {
          "match": {
            "reason_in": [
              "sql_user_value"
            ]
          },
          "replace": {
            "kind": "sql_user",
            "pattern": "dbuser{n:02d}",
            "start": 1,
            "step": 1
          }
        },
        {
          "match": {
            "reason_in": [
              "sql_port_value"
            ]
          },
          "replace": {
            "kind": "port_seq",
            "start": 12345,
            "step": 1
          }
        },
        {
          "match": {
            "reason_in": [
              "sql_database_value"
            ]
          },
          "replace": {
            "kind": "sql_database",
            "fixed": "ipcom_demo"
          }
        },
        {
          "match": {
            "reason_in": [
              "private_key_value",
              "private_key_value_seg"
            ]
          },
          "replace": {
            "kind": "path_private_key",
            "fixed": "/etc/ssl/private/example-key.pem"
          }
        },
        {
          "match": {
            "reason_in": [
              "public_key_value",
              "public_key_value_seg"
            ]
          },
          "replace": {
            "kind": "path_public_key",
            "fixed": "/etc/ssl/certs/example-cert.pem"
          }
        }
      ]
    },
    "api_ports": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "kind": "port_seq",
        "start": 12345,
        "step": 1
      }
    },
    "db_ports": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "kind": "port_seq",
        "start": 12345,
        "step": 1
      }
    },
    "receiver_ports": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "kind": "port_seq",
        "start": 12345,
        "step": 1
      }
    },
    "outputs_ip_whitelist": {
      "render_mode": "replace",
      "fallback_render_mode": "fill",
      "replace": {
        "kind": "ipv4_seq",
        "start": "123.123.123.123",
        "step": 1
      }
    },
    "users_name_login_non_admin": {
      "render_mode": "blur",
      "fallback_render_mode": "fill",
      "blur": {
        "radius": 7
      }
    },
    "objects_uid_iccid": {
      "render_mode": "blur",
      "fallback_render_mode": "fill",
      "blur": {
        "radius": 7
      }
    }
  }
